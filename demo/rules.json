[
  {
    "fromField": "firstName",
    "toField": "Полное имя",
    "exp": "#root['firstName'] + ' ' + #root['lastName']"
  },
  {
    "fromField": "address",
    "toField": "Локация",
    "exp": "#root['address']['city'] + (#root['address']['street'] != null ? ', ' + #root['address']['street'] : ' (Адрес не указан)')"
  },
  {
    "fromField": "age",
    "toField": "Категория",
    "exp": "#root['age'] >= 30 ? 'Senior' : 'Junior'"
  },
  {
    "fromField": "date",
    "toField": "Год регистрации",
    "exp": "#root['date'].substring(0, 4)"
  },
  {
    "fromField": "middleName",
    "toField": "Наличие отчества",
    "exp": "#root['middleName'] == null ? 'Отсутствует' : 'Указано'"
  },
  {
    "fromField": "lastName",
    "toField": "Инициалы",
    "exp": "#root['firstName'].substring(0, 1) + '.' + #root['lastName'].substring(0, 1) + '.'"
  },
  {
    "fromField": "id",
    "toField": "Системный код",
    "exp": "'ID-' + #root['id'] + '-' + #root['address']['city'].toUpperCase().substring(0, 3)"
  }
]